<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_activity_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

  <androidx.appcompat.widget.Toolbar
      android:id="@+id/main_activity_toolbar"
      android:layout_width="match_parent"
      android:layout_height="?attr/actionBarSize"
      android:background="?attr/colorPrimary"
      android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
      app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
      app:title="@string/app_name" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">
    <Button
      android:text="Display Modal"
      android:id="@+id/com_appboy_display_modal_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>
    <Button
      android:text="Display Slideup"
      android:id="@+id/com_appboy_display_slideup_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>
    <Button
      android:text="Flush Data"
      android:id="@+id/com_appboy_flush_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>
  </LinearLayout>
  <fragment android:name="com.braze.ui.contentcards.ContentCardsFragment"
            android:id="@+id/com_braze_content_cards_fragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
</LinearLayout>
