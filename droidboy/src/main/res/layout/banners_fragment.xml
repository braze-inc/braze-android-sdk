<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="250dp">

        <!-- Section for Refreshing Banners by Placement ID -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/banners_refresh_header"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/sailec_bold"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/refresh_banners_input_layout"
            style="@style/DroidboyOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/banners_refresh_input_hint"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/refresh_banners_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/BaseWidget.DroidboyTextInput"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/refresh_banners_button"
            style="@style/DroidboyOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/banners_refresh_button"
            android:layout_marginBottom="24dp"/>

        <!-- Section for Displaying a Specific Banner by its Unique ID -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/banners_get_header"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/sailec_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/banners_cached_placement_ids_label"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/sailec_bold"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cached_placement_ids_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:chipSpacing="8dp"
            app:singleLine="false" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/get_banner_input_layout"
            style="@style/DroidboyOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/banners_get_input_hint"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/get_banner_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/BaseWidget.DroidboyTextInput"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/banner_slot_spinner_layout"
            style="@style/DroidboyOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/banners_slot_spinner_hint"
            android:layout_marginBottom="16dp">

            <Spinner
                android:id="@+id/banner_slot_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/get_banner_button"
            style="@style/DroidboyOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/banners_get_button"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/banners_slots_header"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/sailec_bold"/>

        <LinearLayout
            android:id="@+id/banners_multi_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/current_banner_placement_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/banners_properties_none_placed_yet"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/sailec_bold"/>

        <!-- Banner Properties Display Area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/banners_properties_header"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/sailec_bold"/>

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/banners_properties_filter_label"
          android:fontFamily="@font/sailec_bold" />

        <!-- Property Filter Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/property_filter_spinner_layout"
            style="@style/DroidboyOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/banners_properties_filter_hint"
            android:layout_marginBottom="16dp">

            <Spinner
                android:id="@+id/property_filter_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/banner_properties_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
